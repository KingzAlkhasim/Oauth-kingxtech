NODE_ENV=development
PORT=8080
LOG_LEVEL=info

# Gateway / proxy identity
GATEWAY_HOSTNAME=proxy.kingxtech.name.ng

# GCP Service Account handshake (optional)
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_APPLICATION_CREDENTIALS=
GCP_PROJECT_ID=

# Commercial model providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Supabase — server-side auth verification + chat history storage.
# SUPABASE_URL / SUPABASE_ANON_KEY should match your frontend's
# VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY (same project).
# SUPABASE_SERVICE_ROLE_KEY is the "service_role" secret from
# Supabase → Settings → API. NEVER expose this to the frontend.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Agentic tool sandbox — confines readProjectFile + executeTerminalCommand
# to this directory. Leave unset to default to the server's cwd.
AGENT_PROJECT_ROOT=

# Open-weights tier (optional)
OPENWEIGHTS_PROVIDER=openrouter
OPENWEIGHTS_API_KEY=
OPENWEIGHTS_BASE_URL=https://openrouter.ai/api/v1
QWEN_MODEL_ID=qwen/qwen-2.5-coder-32b-instruct
GEMMA_MODEL_ID=google/gemma-2-27b-it

# ACME / domain verification
ACME_ENABLED=false
ACME_ACCOUNT_EMAIL=
ACME_DIRECTORY_URL=https://acme-v02.api.letsencrypt.org/directory
ACME_CHALLENGE_TYPE=http-01

# CORS — comma-separated list of origins allowed to call this API
ALLOWED_ORIGINS=https://kingxtech.name.ng,https://auth.kingxtech.name.ng
